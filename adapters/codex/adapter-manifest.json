{
  "adapter_id": "codex",
  "workflow_id": "software-project-governance",
  "entry_type": "half-executable",
  "supported_runtime": ["Codex CLI", "Codex-compatible coding agents"],
  "trigger": [
    "Before starting a software project task that changes workflow assets",
    "When implementing, validating, or updating project-governance workflow behavior"
  ],
  "inputs": [
    "skills/software-project-governance/SKILL.md",
    "skills/software-project-governance/references/stage-gates.md",
    "skills/software-project-governance/references/lifecycle.md",
    ".governance/plan-tracker.md"
  ],
  "outputs": [
    ".governance/plan-tracker.md",
    ".governance/evidence-log.md",
    ".governance/decision-log.md",
    ".governance/risk-log.md"
  ],
  "gate_behavior": {
    "on_fail": "block-next-stage",
    "required_action": "update-risk-or-decision-log"
  },
  "validation": {
    "command": "python scripts/verify_workflow.py",
    "required": true
  },
  "replacement_boundary": {
    "keep": [
      "protocol/",
      "workflows/software-project-governance/",
      "scripts/verify_workflow.py"
    ],
    "remove": [
      "adapters/codex/"
    ]
  },
  "launcher": "adapters/codex/launch.py"
}
