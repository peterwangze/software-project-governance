  "loop_policy": {
    "scope": "per-flow-unit",
    "runtime_activation": false,
    "allowed_loop_types": [
      "validation-retry",
      "defect-rework",
      "release-candidate-fix",
      "operations-feedback",
      "maintenance-follow-up"
    ],
    "blocked_dependency_rule": "A blocked flow unit blocks only declared downstream dependents.",
    "sibling_completion_rule": "Passing one flow unit gate does not imply sibling flow units have passed.",
    "loop_counter_policy": "schema-only-recorded-by-future-runtime"
  },
  "flow_unit_schema": {
    "schema_only": true,
    "status_activation": "not-active-in-0.51.0",
    "required_fields": [
      "flow_unit_id",
      "title",
      "unit_type",
      "project_type",
      "lifecycle_mode",
      "current_stage",
      "current_subphase",
      "gate_lane",
      "gate_references",
      "allowed_next_transitions",
      "dependencies",
      "blockers",
      "evidence_refs",
      "loop_state",
      "runtime_status_source"
    ],
    "optional_fields": [
      "owner",
      "risk_level",
      "quality_budget",
      "acceptance_template",
      "rollup_weight",
      "release_target"
    ],
    "allowed_unit_types": [
      "chapter",
      "level",
      "asset",
      "engine-system",
      "story",
      "module",
      "screen",
      "api-surface",
      "command",
      "adapter",
      "skill",
      "manifest",
      "script",
      "job",
      "release-candidate",
      "hotfix"
    ],
    "allowed_gate_lanes": [
      "backlog",
      "design",
      "development",
      "testing",
      "release-candidate",
      "released",
      "operations-feedback",
      "maintenance",
      "blocked"
    ],
    "field_definitions": {
      "flow_unit_id": "Stable machine-readable id, for example game.chapter.03.",
      "current_stage": "One of the stage_vocabulary ids.",
      "current_subphase": "One of the declared subphase ids.",
      "gate_references": "Classic G1-G11 gate references that frame the evidence expectations.",
      "runtime_status_source": "Must say example-data-only or future-runtime; 0.51.0 uses example-data-only."
    }
  },
  "project_type_hooks": {
    "game": {
      "unit_templates": [
        "chapter",
        "level",
        "asset",
        "engine-system"
      ],
      "default_flow_unit_type": "chapter",
      "stage_hooks": {
        "architecture": [
          "chapter-brief",
          "story-outline",
          "technical-design"
        ],
        "development": [
          "implementation",
          "playable-slice"
        ],
        "testing": [
          "playable-smoke",
          "narrative-continuity",
          "performance-budget",
          "regression"
        ],
        "release": [
          "release-candidate",
          "release-notes"
        ],
        "operations": [
          "operations-feedback",
          "defect-budget"
        ]
      },
      "gate_hooks": {
        "chapter_design": [
          "G5"
        ],
        "chapter_development": [
          "G6"
        ],
        "chapter_testing": [
          "G7"
        ],
        "chapter_release": [
          "G8",
          "G9"
        ],
        "chapter_feedback": [
          "G10",
          "G11"
        ]
      }
    },
    "web-app": {
      "unit_templates": [
        "story",
        "module",
        "release-candidate"
      ],
      "default_flow_unit_type": "story",
      "stage_hooks": {
        "architecture": [
          "user-flow",
          "api-contract"
        ],
        "testing": [
          "e2e",
          "accessibility",
          "security"
        ]
      }
    },
    "mobile-app": {
      "unit_templates": [
        "story",
        "screen",
        "release-candidate"
      ],
      "default_flow_unit_type": "story",
      "stage_hooks": {
        "testing": [
          "device-matrix",
          "offline-behavior",
          "store-readiness"
        ]
      }
    },
    "library": {
      "unit_templates": [
        "module",
        "api-surface",
        "release-candidate"
      ],
      "default_flow_unit_type": "module",
      "stage_hooks": {
        "release": [
          "semver",
          "docs",
          "downstream-tests"
        ]
      }
    },
    "cli-tool": {
      "unit_templates": [
        "command",
        "module",
        "release-candidate"
      ],
      "default_flow_unit_type": "command",
      "stage_hooks": {
        "testing": [
          "command-matrix",
          "stderr-contract",
          "exit-codes"
        ]
      }
    },
    "ai-agent-plugin": {
      "unit_templates": [
        "adapter",
        "skill",
        "manifest",
        "release-candidate"
      ],
      "default_flow_unit_type": "skill",
      "stage_hooks": {
        "testing": [
          "runtime-e2e",
          "projection-sync",
          "no-overclaim"
        ]
      }
    },
    "internal-script": {
      "unit_templates": [
        "script",
        "job"
      ],
      "default_flow_unit_type": "script",
      "stage_hooks": {
        "testing": [
          "dry-run",
          "rollback",
          "idempotency"
        ]
      }
    }
  },
