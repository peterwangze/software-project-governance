{
  "$schema": "https://example.com/software-project-governance/lifecycle-registry-v1.json",
  "schema_version": "1.0",
  "workflow": "software-project-governance",
  "workflow_version": "0.50.3",
  "introduced_for": "0.51.0",
  "source_of_truth": true,
  "registry_mode": "schema-only-no-runtime-activation",
  "active_lifecycle_mode": "classic-phase-gate",
  "default_lifecycle_mode": "classic-phase-gate",
  "runtime_activation": {
    "flow_unit_status_runtime": false,
    "project_migration": false,
    "declarative_gate_engine": false,
    "release_bump": false
  },
  "no_overclaim_boundary": [
    "Schema-only registry does not activate flow-unit runtime behavior.",
    "Schema-only registry does not migrate projects.",
    "Schema-only registry does not replace classic G1-G11 behavior.",
    "Schema-only registry does not close RISK-036.",
    "Schema-only registry does not close RISK-037.",
    "Schema-only registry does not claim 1.0.0 production-ready."
  ],
  "lifecycle_modes": [
    {
      "id": "classic-phase-gate",
      "title": "Classic Phase-Gate",
      "status": "active-compatibility-preset",
      "active": true,
      "default": true,
      "compatibility_preset": true,
      "runtime_behavior": "existing-g1-g11",
      "flow_unit_behavior": "not-active",
      "stage_sequence": [
        "initiation",
        "research",
        "selection",
        "infrastructure",
        "architecture",
        "development",
        "testing",
        "ci-cd",
        "release",
        "operations",
        "maintenance"
      ],
      "gate_sequence": [
        "G1",
        "G2",
        "G3",
        "G4",
        "G5",
        "G6",
        "G7",
        "G8",
        "G9",
        "G10",
        "G11"
      ]
    },
    {
      "id": "dynamic-flow-gate",
      "title": "Dynamic Flow-Gate",
      "status": "schema-only-inactive",
      "active": false,
      "default": false,
      "compatibility_preset": false,
      "runtime_behavior": "declared-only",
      "flow_unit_behavior": "schema-only",
      "stage_sequence": [
        "initiation",
        "research",
        "selection",
        "infrastructure",
        "architecture",
        "development",
        "testing",
        "ci-cd",
        "release",
        "operations",
        "maintenance"
      ],
      "gate_sequence": [
        "G1",
        "G2",
        "G3",
        "G4",
        "G5",
        "G6",
        "G7",
        "G8",
        "G9",
        "G10",
        "G11"
      ]
    }
  ],
  "stage_vocabulary": [
    {
      "id": "initiation",
      "number": 1,
      "label": "Initiation and goal definition",
      "gate_out": "G1",
      "allowed_subphases": [
        "project-charter",
        "scope-boundary",
        "risk-baseline"
      ]
    },
    {
      "id": "research",
      "number": 2,
      "label": "Research and competitive analysis",
      "gate_out": "G2",
      "allowed_subphases": [
        "market-research",
        "technical-research",
        "user-research"
      ]
    },
    {
      "id": "selection",
      "number": 3,
      "label": "Technical selection and solution preview",
      "gate_out": "G3",
      "allowed_subphases": [
        "candidate-evaluation",
        "poc",
        "decision-record"
      ]
    },
    {
      "id": "infrastructure",
      "number": 4,
      "label": "Environment and infrastructure",
      "gate_out": "G4",
      "allowed_subphases": [
        "dev-environment",
        "repo-setup",
        "ci-baseline"
      ]
    },
    {
      "id": "architecture",
      "number": 5,
      "label": "Architecture design",
      "gate_out": "G5",
      "allowed_subphases": [
        "backlog",
        "chapter-brief",
        "story-outline",
        "technical-design",
        "design-review"
      ]
    },
    {
      "id": "development",
      "number": 6,
      "label": "Development implementation",
      "gate_out": "G6",
      "allowed_subphases": [
        "implementation",
        "playable-slice",
        "code-review",
        "unit-smoke"
      ]
    },
    {
      "id": "testing",
      "number": 7,
      "label": "Testing and quality assurance",
      "gate_out": "G7",
      "allowed_subphases": [
        "test-plan",
        "quality-validation",
        "regression",
        "release-candidate"
      ]
    },
    {
      "id": "ci-cd",
      "number": 8,
      "label": "Safety net and CI/CD",
      "gate_out": "G8",
      "allowed_subphases": [
        "automation",
        "quality-gate",
        "deployment-pipeline"
      ]
    },
    {
      "id": "release",
      "number": 9,
      "label": "Release",
      "gate_out": "G9",
      "allowed_subphases": [
        "release-plan",
        "release-candidate",
        "released",
        "rollback-ready"
      ]
    },
    {
      "id": "operations",
      "number": 10,
      "label": "Operations and feedback",
      "gate_out": "G10",
      "allowed_subphases": [
        "released",
        "operations-feedback",
        "telemetry",
        "user-feedback"
      ]
    },
    {
      "id": "maintenance",
      "number": 11,
      "label": "Maintenance and evolution",
      "gate_out": "G11",
      "allowed_subphases": [
        "maintenance-fix",
        "loop-rework",
        "retrospective",
        "next-round-planning"
      ]
    }
  ],
