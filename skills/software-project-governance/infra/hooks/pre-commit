#!/bin/bash
# pre-commit governance hook — installed by software-project-governance
# Runs BEFORE every git commit. BLOCKS commits that don't meet governance criteria.
# Design assumption: agent WILL NOT follow rules voluntarily. System MUST enforce.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")

# --- Check if governance is initialized ---
if [ ! -f "$REPO_ROOT/.governance/plan-tracker.md" ]; then
    # Not initialized — allow commit without governance checks
    exit 0
fi

# --- Step 1: Extract task ID from commit message ---
# On Windows git bash, $1 may be empty for 'git commit -m'. Try multiple sources.
COMMIT_MSG=""
# Source 1: explicit file argument (works for 'git commit' with editor)
if [ -n "$1" ] && [ -f "$1" ]; then
    COMMIT_MSG=$(cat "$1" 2>/dev/null)
fi
# Source 2: prepare-commit-msg bridge (cross-platform workaround)
if [ -z "$COMMIT_MSG" ] && [ -f "$REPO_ROOT/.git/GOV_COMMIT_MSG" ]; then
    COMMIT_MSG=$(cat "$REPO_ROOT/.git/GOV_COMMIT_MSG" 2>/dev/null)
fi
# Source 3: git's commit message file (fallback, with staleness check)
# On Windows, git commit -m may leave stale COMMIT_EDITMSG from previous commit.
# Check mtime: if modified within last 60 seconds, it's from THIS commit.
# Window is 60s (not 5s) because Windows file system latency (AV, indexing, etc.)
# can delay the hook execution beyond 5s after git writes COMMIT_EDITMSG.
# Without this, all version-bump commits required --no-verify bypass.
if [ -z "$COMMIT_MSG" ] && [ -f "$REPO_ROOT/.git/COMMIT_EDITMSG" ]; then
    EDITMSG_STALE=0
    # Try to get mtime in seconds since epoch
    EDITMSG_MTIME=$(stat -c %Y "$REPO_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null || stat -f %m "$REPO_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null || echo "0")
    NOW=$(date +%s 2>/dev/null || echo "0")
    if [ "$NOW" -gt 0 ] && [ "$EDITMSG_MTIME" -gt 0 ]; then
        AGE=$((NOW - EDITMSG_MTIME))
        if [ "$AGE" -le 60 ]; then
            COMMIT_MSG=$(cat "$REPO_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null)
        else
            EDITMSG_STALE=1
        fi
    else
        # Cannot determine mtime — trust the file
        COMMIT_MSG=$(cat "$REPO_ROOT/.git/COMMIT_EDITMSG" 2>/dev/null)
    fi
fi
# Source 4: explicit $1 retry (on some Windows git versions, $1 may be the message
# but fails the [ -f "$1" ] check due to path format differences)
if [ -z "$COMMIT_MSG" ] && [ -n "$1" ]; then
    COMMIT_MSG=$(cat "$1" 2>/dev/null || true)
fi

# Extract task ID from first line of whatever we got
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
TASK_ID=$(echo "$FIRST_LINE" | grep -oE '^[A-Z]+-[0-9]+' || true)

# If we still can't get the commit message, skip blocking (post-commit will catch)
if [ -z "$COMMIT_MSG" ]; then
    echo "⚠️  GOVERNANCE: Cannot read commit message. Skipping pre-commit check."
    echo "   post-commit hook will verify governance."
    exit 0
fi

# --- Step 2: Task ID must be present ---
if [ -z "$TASK_ID" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  GOVERNANCE BLOCKED: Commit message has NO task ID.         ║"
    echo "║                                                            ║"
    echo "║  Every commit MUST reference a plan-tracker task.           ║"
    echo "║  Format: 'AUDIT-XXX: description' or 'FIX-XXX: description' ║"
    echo "║                                                            ║"
    echo "║  Action: Add task to plan-tracker, then use its ID.         ║"
    echo "║  Emergency bypass: git commit --no-verify                   ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

# --- Step 3: Task MUST exist in plan-tracker ---
if ! grep -q "| $TASK_ID |" "$REPO_ROOT/.governance/plan-tracker.md" 2>/dev/null; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  GOVERNANCE BLOCKED: Task '$TASK_ID' not in plan-tracker.  ║"
    echo "║                                                            ║"
    echo "║  You are committing work that was never planned.            ║"
    echo "║  This violates M7.5: Pre-Task Protocol.                     ║"
    echo "║                                                            ║"
    echo "║  Action: Add '$TASK_ID' to .governance/plan-tracker.md      ║"
    echo "║          THEN retry the commit.                             ║"
    echo "║  Emergency bypass: git commit --no-verify                   ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

# --- Step 4: Check evidence exists (WARN only — don't block) ---
if [ -f "$REPO_ROOT/.governance/evidence-log.md" ]; then
    if ! grep -qE "$TASK_ID" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null; then
        echo ""
        echo "⚠️  GOVERNANCE: Task '$TASK_ID' has no evidence yet."
        echo "   Commit allowed, but MUST add evidence this session."
        echo ""
    fi
fi

# --- Step 4.5: Task-to-task evidence chain (跨任务防护) ---
# When starting a NEW task, verify previous task's evidence is complete
if [ -f "$REPO_ROOT/.governance/evidence-log.md" ] && [ -f "$REPO_ROOT/.governance/plan-tracker.md" ]; then
    PREV_TASK=$(git log -1 --format=%s 2>/dev/null | grep -oE '^[A-Z]+-[0-9]+' || true)
    if [ -n "$PREV_TASK" ] && [ "$PREV_TASK" != "$TASK_ID" ]; then
        # This is a different task from the last commit — check if previous is clean
        if ! grep -qE "$PREV_TASK" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null; then
            echo ""
            echo "╔══════════════════════════════════════════════════════════════╗"
            echo "║  M7.4 DEBT: Previous task '$PREV_TASK' has NO evidence.    ║"
            echo "║                                                            ║"
            echo "║  You are starting '$TASK_ID' while '$PREV_TASK' is          ║"
            echo "║  incomplete. Each task MUST be fully closed before moving   ║"
            echo "║  to the next. Evidence → check-governance → audit.          ║"
            echo "║                                                            ║"
            echo "║  Commit allowed, but MUST fix '$PREV_TASK' evidence first.  ║"
            echo "╚══════════════════════════════════════════════════════════════╝"
            echo ""
        fi
    fi
fi

# --- Step 5: Check if commit message references work in progress ---
if grep -qiE "wip|work in progress|临时|tmp|temp" <<< "$COMMIT_MSG"; then
    echo ""
    echo "⚠️  GOVERNANCE: Commit message indicates WIP/TEMP work."
    echo "   This is fine for local branches but should be squashed before merge."
    echo ""
fi

# --- Step 6: Bootstrap change discipline (CLAUDE.md direct modification guard) ---
# Rule: MUST NOT directly modify CLAUDE.md to add new behaviors.
# MUST first modify commands/governance-init.md Step 7 (canonical source), bump version,
# then user /plugin update → bootstrap self-upgrade → CLAUDE.md synced.
if git diff --cached --name-only 2>/dev/null | grep -q "^CLAUDE.md$"; then
    if ! git diff --cached --name-only 2>/dev/null | grep -q "^commands/governance-init.md$"; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║  BOOTSTRAP DISCIPLINE: CLAUDE.md modified directly.         ║"
        echo "║                                                            ║"
        echo "║  CLAUDE.md is a dogfood instance — NOT the canonical       ║"
        echo "║  source. New governance behaviors MUST be added to:        ║"
        echo "║    commands/governance-init.md Step 7 (canonical template)  ║"
        echo "║                                                            ║"
        echo "║  The correct flow:                                         ║"
        echo "║  1. Modify governance-init.md template (canonical source)   ║"
        echo "║  2. Bump version                                           ║"
        echo "║  3. User /plugin update → bootstrap self-upgrade           ║"
        echo "║  4. CLAUDE.md auto-synced via bootstrap                    ║"
        echo "║                                                            ║"
        echo "║  If governance-init.md IS also in this commit, both files  ║"
        echo "║  must be modified in the correct order: template FIRST,    ║"
        echo "║  then dogfood CLAUDE.md synced.                            ║"
        echo "║                                                            ║"
        echo "║  This violation has occurred 4+ times. The discipline      ║"
        echo "║  exists because direct CLAUDE.md edits leave users behind. ║"
        echo "║  Emergency bypass: git commit --no-verify                  ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
        # BLOCKING — this discipline has been violated 5+ times.
        # The warning was not sufficient to change behavior.
        # Legitimate non-governance CLAUDE.md changes should still include
        # governance-init.md if they touch the bootstrap section.
        # Emergency bypass: git commit --no-verify
        exit 1
    fi
fi

# ── Step 7a: Review evidence WARN (AUDIT-086) ──
# For P0 tasks, check if a review evidence entry exists.
# This enforces the Producer-Reviewer separation at the system level.
# WARN only — detected gap is logged but commit proceeds.
if [ -f "$REPO_ROOT/.governance/evidence-log.md" ]; then
    TASK_ID=$(echo "$COMMIT_MSG" | grep -oE '(AUDIT|FIX|REQ|MAINT|INIT|PLAN|DESIGN|REL|VAL|CI|ACCEPT|RESEARCH|DOC|OPS|CONSTRAINT|SYSGAP|CLEANUP)-[0-9]+' | head -1)
    if [ -n "$TASK_ID" ]; then
        # Check if the task is P0 priority
        if [ -f "$REPO_ROOT/.governance/plan-tracker.md" ]; then
            IS_P0=$(grep -c "| $TASK_ID |.*| P0 |" "$REPO_ROOT/.governance/plan-tracker.md" 2>/dev/null || echo "0")
            if [ "$IS_P0" -gt 0 ]; then
                # Check for review evidence (REVIEW-* or EVD-* mentioning review)
                HAS_REVIEW=$(grep -c "REVIEW-\|审查" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null || echo "0")
                if [ "$HAS_REVIEW" -eq 0 ]; then
                    echo ""
                    echo "╔══════════════════════════════════════════════════════════════╗"
                    echo "║  REVIEW GAP: P0 task '$TASK_ID' has no review evidence.      ║"
                    echo "║                                                            ║"
                    echo "║  Producer-Reviewer separation requires independent review    ║"
                    echo "║  for all P0 tasks. Run /governance-review before commit.     ║"
                    echo "║                                                            ║"
                    echo "║  This is a WARNING — commit allowed but review debt          ║"
                    echo "║  is being tracked. Fix in next commit.                      ║"
                    echo "╚══════════════════════════════════════════════════════════════╝"
                    echo ""
                    # WARNING only (not BLOCKING) — review can be post-commit for now
                fi
            fi
        fi
    fi
fi

# ── Step 7b: Review evidence BLOCK (SYSGAP-032) ──
# For P0 tasks + product code changes, BLOCK commit if no review evidence.
# Task prefix determines whether review is required (routing table mapping).
# Tasks whose type IS review (REVIEW, EVD, DEC, RISK, GOV) are exempt.
if [ -n "$TASK_ID" ] && [ "$IS_P0" -gt 0 ]; then
    # Determine if this commit touches product code
    # (same definition as Step 9 — see SKILL.md "产品代码 vs 治理记录边界")
    CHANGED_FILES_STEP7=$(git diff --cached --name-only 2>/dev/null || true)
    IS_PRODUCT_CODE_STEP7=0
    if [ -n "$CHANGED_FILES_STEP7" ]; then
        echo "$CHANGED_FILES_STEP7" | grep -qE "^skills/software-project-governance/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^agents/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^skills/stage-" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^skills/[a-z]+-review/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^skills/code-review/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^commands/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^infra/verify_workflow\.py$" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^infra/cleanup\.py$" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^infra/hooks/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^\.claude-plugin/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^\.codex-plugin/" && IS_PRODUCT_CODE_STEP7=1
        echo "$CHANGED_FILES_STEP7" | grep -qE "^skills/software-project-governance/references/" && IS_PRODUCT_CODE_STEP7=1
    fi

    if [ "$IS_PRODUCT_CODE_STEP7" -eq 1 ]; then
        # Task prefix → review requirement mapping
        TASK_PREFIX=$(echo "$TASK_ID" | grep -oE '^[A-Z]+')
        case "$TASK_PREFIX" in
            SYSGAP|AUDIT|FIX|MAINT|CLEANUP|DESIGN|INIT|REL|VAL|CI|ACCEPT|RESEARCH|DOC|OPS|CONSTRAINT|PLAN)
                NEEDS_REVIEW=1 ;;
            REVIEW|EVD|DEC|RISK|GOV)
                NEEDS_REVIEW=0 ;;
            *)
                NEEDS_REVIEW=0 ;;
        esac

        if [ "$NEEDS_REVIEW" -eq 1 ]; then
            HAS_REVIEW_EVD=$(grep -cE "REVIEW-.*$TASK_ID" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null || echo "0")
            if [ "$HAS_REVIEW_EVD" -eq 0 ]; then
                echo ""
                echo "╔══════════════════════════════════════════════════════════════╗"
                echo "║  REVIEW BLOCKED: P0 task '$TASK_ID' has no review evidence. ║"
                echo "║                                                            ║"
                echo "║  Product code changes require independent review (M7.4      ║"
                echo "║  step 4.5). Spawn a Reviewer agent and complete review       ║"
                echo "║  before retrying this commit.                               ║"
                echo "║                                                            ║"
                echo "║  Action: spawn Reviewer agent and complete review.          ║"
                echo "║          The review conclusion MUST be in evidence-log.     ║"
                echo "║  Emergency bypass: git commit --no-verify                  ║"
                echo "╚══════════════════════════════════════════════════════════════╝"
                echo ""
                exit 1
            fi
        fi
    fi
fi

# --- Step 8: Commit Scope WARN (SYSGAP-006) ---
# Group staged files by top-level directory. Warn if commit spans
# too many unrelated directories. This enforces single-concern commits.
# WARN at 3+ directories, [SCOPE-CRITICAL] at 5+ directories.
# Never blocks — cross-directory changes have legitimate use cases
# (migrations, refactors) but should be explained in commit message.
CHANGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
if [ -n "$CHANGED_FILES" ]; then
    SCOPE_DIRS=$(echo "$CHANGED_FILES" | awk -F/ '{if (NF>1) print $1; else print "(root)"}' | sort -u)
    SCOPE_COUNT=$(echo "$SCOPE_DIRS" | grep -c . 2>/dev/null || echo "0")
    if [ "$SCOPE_COUNT" -ge 5 ]; then
        SCOPE_LIST=$(echo "$SCOPE_DIRS" | tr '\n' ' ')
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║  [SCOPE-CRITICAL] GOVERNANCE: Scope Warning                ║"
        echo "║                                                            ║"
        echo "║  This commit touches $SCOPE_COUNT unrelated directories:"
        echo "║    $SCOPE_LIST"
        echo "║                                                            ║"
        echo "║  Consider splitting into separate commits                   ║"
        echo "║  (one per logical change).                                 ║"
        echo "║                                                            ║"
        echo "║  Commit allowed, but scope discipline is expected.         ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
    elif [ "$SCOPE_COUNT" -ge 3 ]; then
        SCOPE_LIST=$(echo "$SCOPE_DIRS" | tr '\n' ' ')
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║  GOVERNANCE: Scope Warning                                 ║"
        echo "║                                                            ║"
        echo "║  This commit touches $SCOPE_COUNT unrelated directories:"
        echo "║    $SCOPE_LIST"
        echo "║                                                            ║"
        echo "║  Consider splitting into separate commits                   ║"
        echo "║  (one per logical change).                                 ║"
        echo "║                                                            ║"
        echo "║  Commit allowed, but scope discipline is expected.         ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
    fi
fi

# --- Step 9: Agent Team Bypass WARN (SYSGAP-007) ---
# Check if this commit modifies "product code" files. If so, verify
# that the commit message shows evidence of Agent Team execution.
# Product code = files under skills/software-project-governance/, agents/,
# skills/stage-*, skills/*-review/, skills/code-review/, commands/,
# infra/ (verify_workflow.py, cleanup.py, hooks/), .claude-plugin/, .codex-plugin/.
# WARN only — emergency hotfixes may need direct commits.
# See SKILL.md "产品代码 vs 治理记录边界" for the full boundary definition.
if [ -n "$CHANGED_FILES" ]; then
    IS_PRODUCT_CODE=0
    echo "$CHANGED_FILES" | grep -qE "^skills/software-project-governance/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^agents/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^skills/stage-" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^skills/[a-z]+-review/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^skills/code-review/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^commands/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^infra/verify_workflow\.py$" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^infra/cleanup\.py$" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^infra/hooks/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^\.claude-plugin/" && IS_PRODUCT_CODE=1
    echo "$CHANGED_FILES" | grep -qE "^\.codex-plugin/" && IS_PRODUCT_CODE=1

    if [ "$IS_PRODUCT_CODE" -eq 1 ]; then
        # Check for Agent Team trace: commit message must start with task ID
        AGENT_TRACE=$(echo "$FIRST_LINE" | grep -oE '^[A-Z]+-[0-9]+:' || true)
        if [ -z "$AGENT_TRACE" ]; then
            echo ""
            echo "╔══════════════════════════════════════════════════════════════╗"
            echo "║  GOVERNANCE: Agent Team bypass detected                    ║"
            echo "║                                                            ║"
            echo "║  This commit modifies product code without evidence of     ║"
            echo "║  Agent Team execution. Coordinator should NOT directly     ║"
            echo "║  modify product code (see SKILL.md product code vs         ║"
            echo "║  governance record boundary).                              ║"
            echo "║                                                            ║"
            echo "║  Commit allowed, but this is a process violation.          ║"
            echo "╚══════════════════════════════════════════════════════════════╝"
            echo ""
        fi
    fi
fi

# ── Step 10: Goal Alignment BLOCK (SYSGAP-023) ──
# Only for product code changes. Checks evidence-log for 目标对齐: field.
# BLOCKING if plan-tracker has 项目目标 but evidence-log has no 目标对齐: for task.
if [ -n "$CHANGED_FILES" ] && [ "${IS_PRODUCT_CODE:-0}" -eq 1 ]; then
    if [ -f "$REPO_ROOT/.governance/plan-tracker.md" ] && [ -f "$REPO_ROOT/.governance/evidence-log.md" ]; then
        HAS_PROJECT_GOAL=$(grep -c '\*\*项目目标\*\*:' "$REPO_ROOT/.governance/plan-tracker.md" 2>/dev/null || echo "0")
        if [ "$HAS_PROJECT_GOAL" -gt 0 ]; then
            # Check if evidence-log has 目标对齐: for this task
            if ! grep -E "^\| EVD-[^|]*\| $TASK_ID \|" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null | grep -q "目标对齐:"; then
                echo ""
                echo "╔══════════════════════════════════════════════════════════════╗"
                echo "║  GOAL ALIGNMENT BLOCKED: Task '$TASK_ID' has NO            ║"
                echo "║  target alignment (目标对齐:) in evidence-log.             ║"
                echo "║                                                            ║"
                echo "║  Every 影响分析 entry MUST include 目标对齐: field         ║"
                echo "║  (min 30 chars) explaining how this change aligns          ║"
                echo "║  with the project goal.                                    ║"
                echo "║                                                            ║"
                echo "║  Action: Add 目标对齐: <description> to evidence-log       ║"
                echo "║          entry for this task, then retry commit.           ║"
                echo "║  Emergency bypass: git commit --no-verify                  ║"
                echo "╚══════════════════════════════════════════════════════════════╝"
                echo ""
                exit 1
            fi
        else
            echo ""
            echo "╔══════════════════════════════════════════════════════════════╗"
            echo "║  GOVERNANCE WARN: plan-tracker missing 项目目标 field.     ║"
            echo "║                                                            ║"
            echo "║  目标对齐: enforcement skipped (no project goal to         ║"
            echo "║  align against). Consider adding 项目目标 to plan-tracker. ║"
            echo "║                                                            ║"
            echo "║  Commit allowed — WARN only.                               ║"
            echo "╚══════════════════════════════════════════════════════════════╝"
            echo ""
        fi
    fi
fi

# ── Step 11: User Impact BLOCK (SYSGAP-024) ──
# Only for product code changes. Checks evidence-log for 用户影响: field.
# BLOCKING if missing.
if [ -n "$CHANGED_FILES" ] && [ "${IS_PRODUCT_CODE:-0}" -eq 1 ]; then
    if [ -f "$REPO_ROOT/.governance/evidence-log.md" ]; then
        if ! grep -E "^\| EVD-[^|]*\| $TASK_ID \|" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null | grep -q "用户影响:"; then
            echo ""
            echo "╔══════════════════════════════════════════════════════════════╗"
            echo "║  USER IMPACT BLOCKED: Task '$TASK_ID' has NO               ║"
            echo "║  user impact analysis (用户影响:) in evidence-log.         ║"
            echo "║                                                            ║"
            echo "║  Every 影响分析 entry MUST include 用户影响: field         ║"
            echo "║  with sub-fields: 获得= / 感知= / 体验变化= / 迁移指南=   ║"
            echo "║                                                            ║"
            echo "║  Action: Add 用户影响: 获得=... 感知=... to evidence-log   ║"
            echo "║          entry for this task, then retry commit.           ║"
            echo "║  Emergency bypass: git commit --no-verify                  ║"
            echo "╚══════════════════════════════════════════════════════════════╝"
            echo ""
            exit 1
        fi
    fi
fi

# ── Step 12: Breaking Change Migration Guide BLOCK (SYSGAP-024) ──
# Only for product code changes. If 体验变化=是 and 迁移指南=不需要 → BLOCKED.
# Also BLOCKED if migration guide path provided but does not exist.
if [ -n "$CHANGED_FILES" ] && [ "${IS_PRODUCT_CODE:-0}" -eq 1 ]; then
    if [ -f "$REPO_ROOT/.governance/evidence-log.md" ]; then
        # Get the 用户影响: line for this task
        USER_IMPACT_LINE=$(grep -E "^\| EVD-[^|]*\| $TASK_ID \|" "$REPO_ROOT/.governance/evidence-log.md" 2>/dev/null | grep "用户影响:" | head -1 || true)
        if [ -n "$USER_IMPACT_LINE" ]; then
            # Check: 体验变化=是 + 迁移指南=不需要
            if echo "$USER_IMPACT_LINE" | grep -q "体验变化=是" && echo "$USER_IMPACT_LINE" | grep -q "迁移指南=不需要"; then
                echo ""
                echo "╔══════════════════════════════════════════════════════════════╗"
                echo "║  BREAKING CHANGE BLOCKED: Task '$TASK_ID' declares        ║"
                echo "║  体验变化=是 (breaking change) but 迁移指南=不需要.        ║"
                echo "║                                                            ║"
                echo "║  Breaking changes MUST provide a migration guide.          ║"
                echo "║  If truly no migration needed, explain why in the          ║"
                echo "║  迁移指南= field with reasoning.                          ║"
                echo "║                                                            ║"
                echo "║  Action: Update evidence-log to provide migration steps    ║"
                echo "║          or explain why no migration is needed.            ║"
                echo "║  Emergency bypass: git commit --no-verify                  ║"
                echo "╚══════════════════════════════════════════════════════════════╝"
                echo ""
                exit 1
            fi
            # Check: 体验变化=是 + migration guide path that doesn't exist
            if echo "$USER_IMPACT_LINE" | grep -q "体验变化=是"; then
                MIGRATION_PATH=$(echo "$USER_IMPACT_LINE" | sed -n 's/.*迁移指南=\([^,，[:space:]]*\).*/\1/p' | head -1 || true)
                if [ -n "$MIGRATION_PATH" ] && [ "$MIGRATION_PATH" != "不需要" ]; then
                    if [ ! -f "$REPO_ROOT/$MIGRATION_PATH" ] && [ ! -f "$MIGRATION_PATH" ]; then
                        echo ""
                        echo "╔══════════════════════════════════════════════════════════════╗"
                        echo "║  MIGRATION GUIDE MISSING: Task '$TASK_ID' references      ║"
                        echo "║  迁移指南=$MIGRATION_PATH but the file does not exist.     ║"
                        echo "║                                                            ║"
                        echo "║  Action: Create the migration guide file or fix the path.  ║"
                        echo "║  Emergency bypass: git commit --no-verify                  ║"
                        echo "╚══════════════════════════════════════════════════════════════╝"
                        echo ""
                        exit 1
                    fi
                fi
            fi
        fi
    fi
fi

# All checks passed
exit 0
